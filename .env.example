# Base de datos Turso (libSQL). Crear en https://turso.tech (gratis, sin tarjeta):
# 1. Crear una base de datos nueva desde el dashboard.
# 2. Copiar la "Database URL" (empieza con libsql://).
# 3. Crear un "Auth Token" y copiarlo.
# Copiar este archivo a .env.local (que no se commitea) y completar los valores reales.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
